---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ThemeIcon from "../components/ThemeIcon.astro";

const themes = (await getCollection("themes")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<BaseLayout title="Alhambra Sustainability Plan">
  <section class="bg-paper">
    <div class="mx-auto max-w-5xl px-4 py-8">
      <h1 class="text-2xl sm:text-3xl font-semibold text-navy leading-tight">
        Alhambra's Sustainability Plan, made browsable.
      </h1>
      <p class="mt-3 text-base text-ink-muted max-w-2xl">
        Pick a theme to see what the city has committed to — in plain language,
        with links back to the source.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-4 py-8">
    <h2 class="sr-only">Sustainability themes</h2>
    <ul class="grid grid-cols-2 gap-3 sm:gap-4 md:grid-cols-3">
      {
        themes.map((theme) => (
          <li>
            <a
              href={`/themes/${theme.data.slug}/`}
              class="group block h-full rounded-xl border border-navy/10 bg-white p-4 shadow-sm transition hover:shadow-md hover:border-navy/30 focus-visible:outline-2 focus-visible:outline-navy focus-visible:outline-offset-2"
            >
              <span
                class="inline-flex h-12 w-12 items-center justify-center rounded-lg text-white"
                style={`background-color: ${theme.data.color}`}
              >
                <ThemeIcon name={theme.data.icon} />
              </span>
              <h3 class="mt-3 text-base font-semibold text-navy group-hover:underline">
                {theme.data.title}
              </h3>
              <p class="mt-1 text-sm text-ink-muted line-clamp-3">
                {theme.data.summary}
              </p>
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
