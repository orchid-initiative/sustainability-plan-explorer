---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ThemeIcon from "../../components/ThemeIcon.astro";

export async function getStaticPaths() {
  const themes = await getCollection("themes");
  return themes.map((theme) => ({
    params: { slug: theme.data.slug },
    props: { theme },
  }));
}

const { theme } = Astro.props;
const { Content } = await render(theme);

const allThemes = await getCollection("themes");
const related = (theme.data.relatedThemes ?? [])
  .map((slug) => allThemes.find((t) => t.data.slug === slug))
  .filter((t): t is NonNullable<typeof t> => Boolean(t));
---

<BaseLayout title={`${theme.data.title} — Alhambra Sustainability Plan`} description={theme.data.summary}>
  <nav aria-label="Breadcrumb" class="bg-paper">
    <div class="mx-auto max-w-3xl px-4 py-3 text-sm">
      <a href={import.meta.env.BASE_URL} class="text-navy underline hover:text-navy/70">← All themes</a>
    </div>
  </nav>

  <article class="mx-auto max-w-3xl px-4 py-6">
    <header class="flex items-start gap-4">
      <span
        class="inline-flex h-14 w-14 shrink-0 items-center justify-center rounded-xl text-white"
        style={`background-color: ${theme.data.color}`}
      >
        <ThemeIcon name={theme.data.icon} class="h-8 w-8" />
      </span>
      <div>
        <h1 class="text-2xl sm:text-3xl font-semibold text-navy leading-tight">
          {theme.data.title}
        </h1>
        <p class="mt-2 text-base text-ink">{theme.data.summary}</p>
      </div>
    </header>

    <div class="mt-6 prose prose-neutral max-w-none text-ink">
      <Content />
    </div>

    <section class="mt-8" aria-labelledby="goals-heading">
      <h2 id="goals-heading" class="text-xl font-semibold text-navy">Goals</h2>
      <ul class="mt-3 space-y-3">
        {
          theme.data.goals.map((goal) => (
            <li>
              <details class="group rounded-xl border border-navy/10 bg-white open:shadow-sm">
                <summary class="flex cursor-pointer list-none items-start gap-3 p-4 focus-visible:outline-2 focus-visible:outline-navy focus-visible:outline-offset-2 rounded-xl">
                  <span
                    class="mt-1 inline-block h-2 w-2 shrink-0 rounded-full"
                    style={`background-color: ${theme.data.color}`}
                    aria-hidden="true"
                  />
                  <span class="flex-1">
                    <span class="block font-semibold text-navy">{goal.title}</span>
                    {goal.description && (
                      <span class="mt-1 block text-sm text-ink-muted">
                        {goal.description}
                      </span>
                    )}
                  </span>
                  <span
                    class="text-navy/60 transition-transform group-open:rotate-180"
                    aria-hidden="true"
                  >▾</span>
                </summary>
                <div class="border-t border-navy/10 px-4 py-3">
                  <h3 class="text-xs font-semibold uppercase tracking-wider text-ink-muted">
                    Actions
                  </h3>
                  <ul class="mt-2 space-y-2">
                    {goal.actions.map((action) => (
                      <li class="text-sm">
                        <p class="text-ink">{action.text}</p>
                        {(action.lead || action.timeline) && (
                          <p class="mt-1 text-xs text-ink-muted">
                            {action.lead && <span>Lead: {action.lead}</span>}
                            {action.lead && action.timeline && <span> · </span>}
                            {action.timeline && <span>{action.timeline}</span>}
                          </p>
                        )}
                      </li>
                    ))}
                  </ul>
                </div>
              </details>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="mt-8 rounded-xl bg-paper p-4 text-sm" aria-labelledby="source-heading">
      <h2 id="source-heading" class="font-semibold text-navy">Source</h2>
      <p class="mt-1 text-ink">{theme.data.source_reference}</p>
      <p class="mt-2">
        <a
          href="https://www.alhambraca.gov/DocumentCenter/View/7621/Alhambra-Sustainability-Plan-Draft"
          class="text-navy underline hover:text-navy/70"
          target="_blank"
          rel="noopener"
        >Open the full Sustainability Plan Draft (PDF) →</a>
      </p>
      <p class="mt-2 text-xs text-ink-muted">
        Last updated {theme.data.lastUpdated.toISOString().slice(0, 10)}
      </p>
    </section>

    {
      related.length > 0 && (
        <section class="mt-8" aria-labelledby="related-heading">
          <h2 id="related-heading" class="text-xl font-semibold text-navy">
            Related themes
          </h2>
          <ul class="mt-3 grid grid-cols-2 gap-3">
            {related.map((r) => (
              <li>
                <a
                  href={`${import.meta.env.BASE_URL}themes/${r.data.slug}/`}
                  class="flex items-center gap-3 rounded-xl border border-navy/10 bg-white p-3 hover:border-navy/30 hover:shadow-sm focus-visible:outline-2 focus-visible:outline-navy focus-visible:outline-offset-2"
                >
                  <span
                    class="inline-flex h-9 w-9 items-center justify-center rounded-lg text-white"
                    style={`background-color: ${r.data.color}`}
                  >
                    <ThemeIcon name={r.data.icon} class="h-5 w-5" />
                  </span>
                  <span class="text-sm font-semibold text-navy">{r.data.title}</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )
    }
  </article>
</BaseLayout>
