---
interface Props {
  name: string;
  class?: string;
}

const { name, class: className = "h-8 w-8" } = Astro.props;

const paths: Record<string, string> = {
  bolt: "M13 2 4 14h7l-1 8 9-12h-7l1-8z",
  droplet: "M12 3s-6 7-6 12a6 6 0 0 0 12 0c0-5-6-12-6-12z",
  bike: "M5 18a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm14 0a3 3 0 1 0 0-6 3 3 0 0 0 0 6zM12 6l3 6h-6l3-6zm0 0V4h2",
  recycle: "M7 19h10l-2-3M5 12l3-5 3 5M19 12l-3 5h-6",
  tree: "M12 3 6 12h3l-3 5h12l-3-5h3L12 3zm0 14v4",
  shield: "M12 3 5 6v6c0 4 3 7 7 9 4-2 7-5 7-9V6l-7-3z",
  sprout: "M12 20v-8M12 12c0-4 3-7 7-7-.2 4-3 7-7 7zM12 12c0-3-2-6-5-6 .2 3 2 6 5 6z",
  users: "M9 11a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm0 2c-3 0-6 1.5-6 4v2h12v-2c0-2.5-3-4-6-4zm9-2a3 3 0 1 0 0-6 3 3 0 0 0 0 6zm0 2c-1 0-1.8.2-2.5.5 1.5 1 2.5 2.5 2.5 4.5v2h5v-2c0-2.5-3-5-5-5z",
  wind: "M3 8h10a3 3 0 1 0-3-3M3 12h16a3 3 0 1 1-3 3M3 16h8a2 2 0 1 1-2 2",
  leaf: "M5 19c0-8 6-14 14-14 0 8-6 14-14 14zM5 19c2-4 6-8 10-10",
};

const d = paths[name] ?? paths.bolt;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.8"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
>
  <path d={d} />
</svg>
