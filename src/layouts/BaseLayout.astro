---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "A community explorer for Alhambra's Sustainability Plan — an independent prototype by Orchid Initiative." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap"
    />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col bg-white text-ink">
    <header class="bg-navy text-paper">
      <div class="mx-auto max-w-5xl px-4 py-4">
        <a href={import.meta.env.BASE_URL} class="inline-block no-underline">
          <span class="block text-base font-semibold">Sustainability Plan Explorer</span>
        </a>
      </div>
    </header>

    <div class="bg-gold text-navy border-b border-navy/20" role="alert">
      <div class="mx-auto max-w-5xl px-4 py-3 text-sm font-medium">
        The City of Alhambra is collecting public feedback on the draft Sustainability Plan through Thursday, April 30. <a
          href="https://form.jotform.com/260825652797066"
          class="underline hover:opacity-80"
          target="_blank"
          rel="noopener"
        >Share your input →</a>
      </div>
    </div>

    <div class="bg-gold/15 border-b border-gold/40 text-ink" role="note">
      <div class="mx-auto max-w-5xl px-4 py-2 text-sm">
        An independent prototype by <a
          href="https://www.orchidinitiative.com"
          class="underline hover:opacity-70"
          target="_blank"
          rel="noopener"
        >Orchid Initiative</a>. <a
          href="https://www.alhambraca.gov/DocumentCenter/View/7621/Alhambra-Sustainability-Plan-Draft"
          class="underline hover:opacity-70"
          target="_blank"
          rel="noopener"
        >Alhambra's official plan is the source of record →</a>
      </div>
    </div>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="bg-navy text-paper mt-12">
      <div class="mx-auto max-w-5xl px-4 py-6 text-sm">
        <p class="opacity-90">
          Built by <a
            href="https://www.orchidinitiative.com"
            class="underline hover:text-gold"
            target="_blank"
            rel="noopener"
          >Orchid Initiative</a> as an unofficial prototype.
          Source content © City of Alhambra. Visit the
          <a
            href="https://www.alhambraca.gov/sustainability"
            class="underline hover:text-gold"
            target="_blank"
            rel="noopener"
          >City's sustainability program</a> for the full picture.
        </p>
      </div>
    </footer>
  </body>
</html>
